{
  "private": false,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace backend run dev\" \"npm --workspace frontend run dev\"",
    "start:backend": "npm --workspace backend start",
    "start:frontend": "npm --workspace frontend run dev",
    "build:frontend": "npm --workspace frontend run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "name": "yacloz",
  "version": "1.0.2"
}
